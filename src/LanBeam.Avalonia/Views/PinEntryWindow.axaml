<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="LanBeam.Ui.Views.PinEntryWindow"
        Title="{DynamicResource Str_PinEntryTitle}"
        Width="400" SizeToContent="Height"
        CanResize="False" WindowStartupLocation="CenterScreen">

    <StackPanel Margin="24">
        <TextBlock Text="{DynamicResource Str_PinEntryTitle}" FontSize="20" FontWeight="SemiBold" />
        <TextBlock x:Name="InfoText" Margin="0,14,0,0" FontSize="14" TextWrapping="Wrap" />
        <TextBlock x:Name="AttemptsText" Margin="0,6,0,0" Classes="dim" />

        <TextBox x:Name="PinBox" Margin="0,16,0,0" FontSize="26" FontFamily="Consolas,monospace"
                 MaxLength="6" TextAlignment="Center" Watermark="######"
                 TextChanged="Pin_TextChanged" KeyDown="Pin_KeyDown" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0" Spacing="10">
            <Button Content="{DynamicResource Str_Dismiss}" MinWidth="100" Click="Cancel_Click" />
            <Button x:Name="OkButton" Content="{DynamicResource Str_Pair}" MinWidth="120"
                    IsEnabled="False" Click="Ok_Click" />
        </StackPanel>
    </StackPanel>
</Window>
