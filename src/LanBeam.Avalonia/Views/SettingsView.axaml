<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="using:LanBeam.Ui.Controls"
             x:Class="LanBeam.Ui.Views.SettingsView">

    <ScrollViewer Padding="4">
        <StackPanel Margin="12,8,12,24">
            <TextBlock Text="{DynamicResource Str_SettingsTitle}" Classes="h1" Margin="0,0,0,12" />

            <ctrl:MasonryPanel ColumnWidth="388">

                <!-- Dil -->
                <StackPanel Margin="0,0,16,16">
                    <TextBlock Text="{DynamicResource Str_Language}" Classes="h2" />
                    <Border Classes="card" Width="372">
                        <ComboBox x:Name="LanguageBox" MinWidth="200" HorizontalAlignment="Left"
                                  SelectionChanged="Language_Changed">
                            <ComboBoxItem Content="Türkçe" />
                            <ComboBoxItem Content="English" />
                        </ComboBox>
                    </Border>
                </StackPanel>

                <!-- Cihaz -->
                <StackPanel Margin="0,0,16,16">
                    <TextBlock Text="{DynamicResource Str_Device}" Classes="h2" />
                    <Border Classes="card" Width="372">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Str_DeviceNameLabel}" Opacity="0.8" FontSize="13" TextWrapping="Wrap" />
                            <TextBox x:Name="DeviceNameBox" Margin="0,6,0,0" MinWidth="260"
                                     HorizontalAlignment="Left" LostFocus="DeviceName_LostFocus" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Avatar -->
                <StackPanel Margin="0,0,16,16">
                    <TextBlock Text="{DynamicResource Str_Avatar}" Classes="h2" />
                    <Border Classes="card" Width="372">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="56" Height="56" CornerRadius="28" ClipToBounds="True"
                                        x:Name="PreviewCircle">
                                    <Panel>
                                        <TextBlock x:Name="PreviewGlyph" FontSize="26"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <Image x:Name="PreviewImage" Stretch="UniformToFill" IsVisible="False" />
                                    </Panel>
                                </Border>
                                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                    <Button Content="{DynamicResource Str_PickPhoto}" Click="PickPhoto_Click" />
                                    <TextBlock Margin="0,6,0,0" Classes="dim" TextWrapping="Wrap" MaxWidth="240"
                                               Text="{DynamicResource Str_AvatarHint}" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource Str_Presets}" Margin="0,12,0,4" FontSize="12" Opacity="0.7" />
                            <WrapPanel x:Name="PresetPanel" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Alım -->
                <StackPanel Margin="0,0,16,16">
                    <TextBlock Text="{DynamicResource Str_FileReceiving}" Classes="h2" />
                    <Border Classes="card" Width="372">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Str_DownloadFolder}" Opacity="0.8" FontSize="13" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0" Spacing="8">
                                <TextBox x:Name="DownloadFolderBox" IsReadOnly="True" Width="250" />
                                <Button Content="{DynamicResource Str_Change}" Click="ChangeFolder_Click" />
                            </StackPanel>
                            <CheckBox x:Name="AlwaysAskBox" Margin="0,10,0,0"
                                      Content="{DynamicResource Str_AlwaysAsk}" IsCheckedChanged="AlwaysAsk_Changed" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Performans -->
                <StackPanel Margin="0,0,16,16">
                    <TextBlock Text="{DynamicResource Str_Performance}" Classes="h2" />
                    <Border Classes="card" Width="372">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{DynamicResource Str_StreamCountLabel}" Opacity="0.8" FontSize="13"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="StreamCountText" FontWeight="Bold" VerticalAlignment="Center" />
                            </StackPanel>
                            <Slider x:Name="StreamSlider" Minimum="1" Maximum="8" TickFrequency="1"
                                    IsSnapToTickEnabled="True" Margin="0,4,0,0"
                                    PropertyChanged="StreamSlider_Changed" />
                            <TextBlock Margin="0,6,0,0" Classes="dim" TextWrapping="Wrap"
                                       Text="{DynamicResource Str_StreamCountHint}" />

                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0" Spacing="8">
                                <TextBlock Text="{DynamicResource Str_PortLabel}" Opacity="0.8" FontSize="13"
                                           VerticalAlignment="Center" />
                                <TextBox x:Name="PortBox" MinWidth="100" LostFocus="Port_LostFocus" />
                            </StackPanel>
                            <TextBlock Margin="0,6,0,0" Classes="dim" TextWrapping="Wrap"
                                       Text="{DynamicResource Str_PortHint}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Sistem -->
                <StackPanel Margin="0,0,16,16">
                    <TextBlock Text="{DynamicResource Str_System}" Classes="h2" />
                    <Border Classes="card" Width="372">
                        <CheckBox x:Name="TrayBox" Content="{DynamicResource Str_MinimizeToTray}"
                                  IsCheckedChanged="Tray_Changed" />
                    </Border>
                </StackPanel>

                <!-- Eşleştirilmiş -->
                <StackPanel Margin="0,0,16,16">
                    <TextBlock Text="{DynamicResource Str_PairedDevices}" Classes="h2" />
                    <Border Classes="card" Width="372">
                        <StackPanel>
                            <TextBlock x:Name="NoTrustedText" Opacity="0.6" FontSize="13" TextWrapping="Wrap"
                                       Text="{DynamicResource Str_NoPaired}" />
                            <ItemsControl x:Name="TrustedList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding FingerprintShort}" Opacity="0.5"
                                                           FontSize="11" FontFamily="Consolas,monospace" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="{DynamicResource Str_Remove}"
                                                    Tag="{Binding DeviceId}" Click="RemoveTrusted_Click" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Hakkında -->
                <StackPanel Margin="0,0,16,16">
                    <TextBlock Text="{DynamicResource Str_About}" Classes="h2" />
                    <Border Classes="card" Width="372">
                        <StackPanel>
                            <TextBlock x:Name="AboutText" FontSize="13" Opacity="0.8" TextWrapping="Wrap" />
                            <TextBlock x:Name="FingerprintText" Margin="0,6,0,0" FontSize="11" Opacity="0.5"
                                       FontFamily="Consolas,monospace" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>

            </ctrl:MasonryPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
