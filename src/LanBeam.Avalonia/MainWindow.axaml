<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:LanBeam.Ui.Views"
        x:Class="LanBeam.Ui.MainWindow"
        Title="LanBeam" Width="980" Height="640"
        MinWidth="720" MinHeight="460"
        WindowStartupLocation="CenterScreen">

    <Grid ColumnDefinitions="200,*">
        <Border Grid.Column="0" Background="#10808080">
            <StackPanel Margin="8,16">
                <TextBlock Text="LanBeam" FontSize="18" FontWeight="Bold" Margin="12,0,0,16" />
                <ListBox x:Name="NavList" Background="Transparent" SelectionChanged="Nav_SelectionChanged">
                    <ListBoxItem Content="{DynamicResource Str_NavDevices}" />
                    <ListBoxItem Content="{DynamicResource Str_NavTransfers}" />
                    <ListBoxItem Content="{DynamicResource Str_NavSettings}" />
                </ListBox>
            </StackPanel>
        </Border>

        <Panel Grid.Column="1" Margin="4,8,12,12">
            <views:DevicesView x:Name="DevicesSection" />
            <views:TransfersView x:Name="TransfersSection" IsVisible="False" />
            <views:SettingsView x:Name="SettingsSection" IsVisible="False" />
        </Panel>
    </Grid>
</Window>
