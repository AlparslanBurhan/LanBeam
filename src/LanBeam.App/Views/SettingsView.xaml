<UserControl
    x:Class="LanBeam.App.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <UserControl.Resources>
        <!-- Kart: sabit genişlik; WrapPanel geniş pencerede 2 sütuna akıtır -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Width" Value="372" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
        <StackPanel Margin="12,8,12,24">
            <TextBlock Text="{DynamicResource Str_SettingsTitle}" FontSize="26" FontWeight="SemiBold" Margin="0,0,0,12" />

            <WrapPanel Orientation="Horizontal">

                <!-- Dil / Language -->
                <StackPanel Margin="0,0,16,16">
                    <TextBlock Text="{DynamicResource Str_Language}" Style="{StaticResource SectionHeader}" />
                    <Border Style="{StaticResource SectionCard}">
                        <ComboBox x:Name="LanguageBox" MinWidth="200" HorizontalAlignment="Left"
                                  SelectionChanged="Language_Changed">
                            <ComboBoxItem Content="Türkçe" Tag="tr" />
                            <ComboBoxItem Content="English" Tag="en" />
                        </ComboBox>
                    </Border>
                </StackPanel>

                <!-- Cihaz -->
                <StackPanel Margin="0,0,16,16">
                    <TextBlock Text="{DynamicResource Str_Device}" Style="{StaticResource SectionHeader}" />
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Str_DeviceNameLabel}" Opacity="0.8" FontSize="13" TextWrapping="Wrap" />
                            <ui:TextBox x:Name="DeviceNameBox" Margin="0,6,0,0"
                                        HorizontalAlignment="Left" MinWidth="260"
                                        LostFocus="DeviceName_LostFocus" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Avatar -->
                <StackPanel Margin="0,0,16,16">
                    <TextBlock Text="{DynamicResource Str_Avatar}" Style="{StaticResource SectionHeader}" />
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="56" Height="56">
                                    <Border x:Name="PreviewPreset" CornerRadius="28">
                                        <TextBlock x:Name="PreviewGlyph" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="26" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Ellipse x:Name="PreviewImage" Visibility="Collapsed" />
                                </Grid>
                                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                    <ui:Button Content="{DynamicResource Str_PickPhoto}" Icon="{ui:SymbolIcon ImageAdd24}"
                                               Click="PickPhoto_Click" />
                                    <TextBlock Margin="0,6,0,0" FontSize="11" Opacity="0.55" TextWrapping="Wrap" MaxWidth="240"
                                               Text="{DynamicResource Str_AvatarHint}" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource Str_Presets}" Margin="0,12,0,4" FontSize="12" Opacity="0.7" />
                            <WrapPanel x:Name="PresetPanel" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Alım -->
                <StackPanel Margin="0,0,16,16">
                    <TextBlock Text="{DynamicResource Str_FileReceiving}" Style="{StaticResource SectionHeader}" />
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Str_DownloadFolder}" Opacity="0.8" FontSize="13" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <ui:TextBox x:Name="DownloadFolderBox" IsReadOnly="True" Width="250" />
                                <ui:Button Content="{DynamicResource Str_Change}" Margin="8,0,0,0" Click="ChangeFolder_Click" />
                            </StackPanel>
                            <CheckBox x:Name="AlwaysAskBox" Margin="0,10,0,0"
                                      Content="{DynamicResource Str_AlwaysAsk}"
                                      Checked="AlwaysAsk_Changed" Unchecked="AlwaysAsk_Changed" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Performans -->
                <StackPanel Margin="0,0,16,16">
                    <TextBlock Text="{DynamicResource Str_Performance}" Style="{StaticResource SectionHeader}" />
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Str_StreamCountLabel}" Opacity="0.8" FontSize="13"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="StreamCountText" FontWeight="Bold" Margin="8,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <Slider x:Name="StreamSlider" Minimum="1" Maximum="8" TickFrequency="1"
                                    IsSnapToTickEnabled="True" Margin="0,8,0,0"
                                    ValueChanged="StreamSlider_ValueChanged" />
                            <TextBlock Margin="0,6,0,0" FontSize="12" Opacity="0.55" TextWrapping="Wrap"
                                       Text="{DynamicResource Str_StreamCountHint}" />

                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <TextBlock Text="{DynamicResource Str_PortLabel}" Opacity="0.8" FontSize="13"
                                           VerticalAlignment="Center" />
                                <ui:TextBox x:Name="PortBox" Margin="8,0,0,0" MinWidth="100"
                                            LostFocus="Port_LostFocus" />
                            </StackPanel>
                            <TextBlock Margin="0,6,0,0" FontSize="12" Opacity="0.55" TextWrapping="Wrap"
                                       Text="{DynamicResource Str_PortHint}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Sistem -->
                <StackPanel Margin="0,0,16,16">
                    <TextBlock Text="{DynamicResource Str_System}" Style="{StaticResource SectionHeader}" />
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <CheckBox x:Name="AutoStartBox" Content="{DynamicResource Str_AutoStart}"
                                      Checked="AutoStart_Changed" Unchecked="AutoStart_Changed" />
                            <CheckBox x:Name="TrayBox" Margin="0,8,0,0"
                                      Content="{DynamicResource Str_MinimizeToTray}"
                                      Checked="Tray_Changed" Unchecked="Tray_Changed" />

                            <Separator Margin="0,12" />

                            <ui:Button x:Name="InstallButton" Content="{DynamicResource Str_Install}"
                                       Icon="{ui:SymbolIcon Desktop24}" Appearance="Primary"
                                       Click="Install_Click" />
                            <TextBlock x:Name="InstallHint" Margin="0,6,0,0" FontSize="12" Opacity="0.55"
                                       TextWrapping="Wrap" Text="{DynamicResource Str_InstallHint}" />

                            <Separator Margin="0,12" />

                            <ui:Button x:Name="ContextMenuButton" Content="{DynamicResource Str_AddContextMenu}"
                                       Icon="{ui:SymbolIcon DocumentAdd24}" Click="ContextMenu_Click" />
                            <ui:Button Content="{DynamicResource Str_RepairFirewall}" Margin="0,8,0,0"
                                       Icon="{ui:SymbolIcon Shield24}" Click="Firewall_Click" />
                            <TextBlock Margin="0,8,0,0" FontSize="12" Opacity="0.55" TextWrapping="Wrap"
                                       Text="{DynamicResource Str_ContextMenuHint}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Güvenilir cihazlar -->
                <StackPanel Margin="0,0,16,16">
                    <TextBlock Text="{DynamicResource Str_PairedDevices}" Style="{StaticResource SectionHeader}" />
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock x:Name="NoTrustedText" Opacity="0.6" FontSize="13" TextWrapping="Wrap"
                                       Text="{DynamicResource Str_NoPaired}" />
                            <ItemsControl x:Name="TrustedList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding FingerprintShort}" Opacity="0.5"
                                                           FontSize="11" FontFamily="Consolas" />
                                            </StackPanel>
                                            <ui:Button Grid.Column="1" Content="{DynamicResource Str_Remove}" Appearance="Secondary"
                                                       Tag="{Binding DeviceId}" Click="RemoveTrusted_Click" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Hakkında -->
                <StackPanel Margin="0,0,16,16">
                    <TextBlock Text="{DynamicResource Str_About}" Style="{StaticResource SectionHeader}" />
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock x:Name="AboutText" FontSize="13" Opacity="0.8" TextWrapping="Wrap" />
                            <TextBlock x:Name="FingerprintText" Margin="0,6,0,0" FontSize="11" Opacity="0.5"
                                       FontFamily="Consolas" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>

            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
