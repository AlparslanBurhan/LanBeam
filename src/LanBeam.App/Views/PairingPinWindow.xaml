<ui:FluentWindow
    x:Class="LanBeam.App.Views.PairingPinWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{DynamicResource Str_PairingTitle}"
    Width="420" SizeToContent="Height"
    ResizeMode="NoResize" Topmost="True"
    ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen" ShowInTaskbar="True">

    <StackPanel Margin="24,36,24,24">
        <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="28"
                           Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
            <TextBlock Text="{DynamicResource Str_PairingTitle}" FontSize="20" FontWeight="SemiBold" Margin="12,0,0,0" />
        </StackPanel>

        <TextBlock x:Name="InfoText" Margin="0,14,0,0" FontSize="14" TextWrapping="Wrap" />

        <Border Margin="0,18,0,0" Padding="20" CornerRadius="10"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <TextBlock x:Name="PinText" FontSize="44" FontWeight="Bold" TextAlignment="Center"
                       FontFamily="Consolas" />
        </Border>

        <StackPanel x:Name="WaitPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" />
            <TextBlock Text="{DynamicResource Str_WaitingForCode}" Margin="10,0,0,0" Opacity="0.7"
                       VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock x:Name="ResultText" Margin="0,16,0,0" FontSize="14" FontWeight="SemiBold"
                   TextAlignment="Center" Visibility="Collapsed" />
    </StackPanel>
</ui:FluentWindow>
