<ui:FluentWindow
    x:Class="LanBeam.App.Views.IncomingOfferWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{DynamicResource Str_IncomingTransfer}"
    Width="440" SizeToContent="Height"
    ResizeMode="NoResize" Topmost="True"
    ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen" ShowInTaskbar="True">

    <StackPanel Margin="24,36,24,24">
        <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="28"
                           Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
            <TextBlock Text="{DynamicResource Str_IncomingTitle}" FontSize="20" FontWeight="SemiBold" Margin="12,0,0,0" />
        </StackPanel>

        <TextBlock x:Name="SenderText" Margin="0,16,0,0" FontSize="14" TextWrapping="Wrap" />

        <Border Margin="0,14,0,0" Padding="14" CornerRadius="8"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <StackPanel>
                <TextBlock x:Name="NameText" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" />
                <TextBlock x:Name="DetailText" Margin="0,6,0,0" Opacity="0.7" FontSize="13" />
            </StackPanel>
        </Border>

        <TextBlock x:Name="DestinationText" Margin="0,12,0,0" FontSize="12" Opacity="0.6"
                   TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <ui:Button Content="{DynamicResource Str_Reject}" MinWidth="100" Click="Reject_Click" />
            <ui:Button Content="{DynamicResource Str_Accept}" Appearance="Primary" MinWidth="120" Margin="10,0,0,0"
                       Icon="{ui:SymbolIcon Checkmark24}" Click="Accept_Click" />
        </StackPanel>
    </StackPanel>
</ui:FluentWindow>
