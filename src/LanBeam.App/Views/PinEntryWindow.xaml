<ui:FluentWindow
    x:Class="LanBeam.App.Views.PinEntryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{DynamicResource Str_PinEntryTitle}"
    Width="400" SizeToContent="Height"
    ResizeMode="NoResize" Topmost="True"
    ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen">

    <StackPanel Margin="24,36,24,24">
        <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="Key24" FontSize="26"
                           Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
            <TextBlock Text="{DynamicResource Str_PinEntryTitle}" FontSize="20" FontWeight="SemiBold" Margin="12,0,0,0" />
        </StackPanel>

        <TextBlock x:Name="InfoText" Margin="0,14,0,0" FontSize="14" TextWrapping="Wrap" />
        <TextBlock x:Name="AttemptsText" Margin="0,6,0,0" FontSize="12" Opacity="0.6" />

        <ui:TextBox x:Name="PinBox" Margin="0,16,0,0" FontSize="26" FontFamily="Consolas"
                    MaxLength="6" TextAlignment="Center" PlaceholderText="######"
                    TextChanged="PinBox_TextChanged" KeyDown="PinBox_KeyDown" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <ui:Button Content="{DynamicResource Str_Dismiss}" MinWidth="100" Click="Cancel_Click" />
            <ui:Button x:Name="OkButton" Content="{DynamicResource Str_Pair}" Appearance="Primary" MinWidth="120"
                       Margin="10,0,0,0" IsEnabled="False" Click="Ok_Click" />
        </StackPanel>
    </StackPanel>
</ui:FluentWindow>
