<UserControl
    x:Class="LanBeam.App.Views.DevicesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="12,8,12,4">
            <TextBlock Text="{DynamicResource Str_DevicesTitle}" FontSize="26" FontWeight="SemiBold" />
            <TextBlock x:Name="SelfInfoText" Margin="0,4,0,0" Opacity="0.7" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="4">
            <Grid>
                <!-- Boş durum -->
                <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="0,60,0,0">
                    <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" />
                    <TextBlock Margin="0,16,0,0" FontSize="16" Opacity="0.8" TextAlignment="Center"
                               Text="{DynamicResource Str_SearchingDevices}" />
                    <TextBlock Margin="0,8,0,0" Opacity="0.55" TextAlignment="Center"
                               TextWrapping="Wrap" MaxWidth="420"
                               Text="{DynamicResource Str_SearchingDevicesHint}" />
                </StackPanel>

                <ItemsControl x:Name="DeviceList" ItemsSource="{Binding Devices}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="270" Margin="8" Padding="16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    AllowDrop="True" Drop="Card_Drop" DragOver="Card_DragOver">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Grid Width="44" Height="44">
                                            <Border CornerRadius="22" Background="{Binding PresetBrush}"
                                                    Visibility="{Binding HasImage, Converter={StaticResource InverseBoolToVis}}">
                                                <TextBlock Text="{Binding PresetGlyph}"
                                                           FontFamily="Segoe MDL2 Assets" FontSize="20"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Ellipse Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
                                                <Ellipse.Fill>
                                                    <ImageBrush ImageSource="{Binding AvatarImage}" Stretch="UniformToFill" />
                                                </Ellipse.Fill>
                                            </Ellipse>
                                        </Grid>
                                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" />
                                            <TextBlock Text="{Binding Address}" Opacity="0.6" FontSize="12" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                                Visibility="{Binding IsTrusted, Converter={StaticResource BoolToVis}}">
                                        <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="14"
                                                       Foreground="{DynamicResource SystemFillColorSuccessBrush}" />
                                        <TextBlock Text="{DynamicResource Str_Paired}" Margin="6,0,0,0" FontSize="12"
                                                   Foreground="{DynamicResource SystemFillColorSuccessBrush}" />
                                    </StackPanel>

                                    <TextBlock Margin="0,10,0,0" FontSize="12" Opacity="0.55"
                                               Text="{DynamicResource Str_DragHint}" TextWrapping="Wrap" />

                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <ui:Button Content="{DynamicResource Str_SendFiles}" Appearance="Primary"
                                                   Icon="{ui:SymbolIcon Send24}"
                                                   Click="SendFiles_Click" />
                                        <ui:Button Content="{DynamicResource Str_Folder}" Margin="8,0,0,0"
                                                   Icon="{ui:SymbolIcon Folder24}"
                                                   Click="SendFolder_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
